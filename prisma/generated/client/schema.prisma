// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
}

model Store {
  id           String      @id @default(cuid())
  name         String
  slug         String      @unique
  /// Subdomínio interno da plataforma, ex: "premium-cars"
  subdomain    String      @unique
  /// Domínio customizado completo, ex: "www.premiumcars.com.br"
  customDomain String?     @unique
  logoUrl      String?
  primaryColor String      @default("#000000")
  whatsapp     String
  status       StoreStatus @default(ACTIVE)
  vehicles     Vehicle[]
  users        User[]
  leadEvents   LeadEvent[]
  createdAt    DateTime    @default(now())
}

enum UserRole {
  SUPER_ADMIN
  STORE_ADMIN
  STORE_USER
}

enum StoreRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      UserRole @default(STORE_ADMIN)
  storeId   String?
  store     Store?   @relation(fields: [storeId], references: [id])
  createdAt DateTime @default(now())
}

model StoreRequest {
  id           String             @id @default(cuid())
  name         String
  email        String
  whatsapp     String
  storeName    String
  subdomain    String
  message      String?
  status       StoreRequestStatus @default(PENDING)
  rejectedNote String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @default(now()) @updatedAt

  @@index([status])
}

model Vehicle {
  id           String         @id @default(cuid())
  make         String
  model        String
  year         Int
  price        Float
  km           Int
  color        String?
  fuelType     String?
  transmission String?
  description  String?
  featured     Boolean        @default(false)
  status       Status         @default(AVAILABLE)
  storeId      String
  store        Store          @relation(fields: [storeId], references: [id])
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @default(now()) @updatedAt
  images       VehicleImage[]
  leadEvents   LeadEvent[]

  @@index([storeId])
  @@index([status])
}

model LeadEvent {
  id               String           @id @default(cuid())
  vehicleId        String?
  vehicle          Vehicle?         @relation(fields: [vehicleId], references: [id])
  storeId          String
  store            Store            @relation(fields: [storeId], references: [id])
  type             String
  contactName      String?
  contactPhone     String?
  attendanceStatus AttendanceStatus @default(PENDING)
  assignedTo       String?
  createdAt        DateTime         @default(now())

  @@index([storeId])
  @@index([attendanceStatus])
}

enum AttendanceStatus {
  PENDING
  IN_PROGRESS
  DONE
}

model VehicleImage {
  id        String  @id @default(cuid())
  url       String
  isCover   Boolean @default(false)
  order     Int     @default(0)
  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])
}

enum Status {
  AVAILABLE
  RESERVED
  SOLD
}

enum StoreStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
}
